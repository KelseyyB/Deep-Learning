    {
      "cell_type": "markdown",
      "source": [
        "In this cell, I initialize the FFN model and print its architecture to verify the layer structure."
      ],
      "metadata": {
        "id": "uMvX-FIrsVF0"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "criterion = nn.CrossEntropyLoss()\n",
        "\n",
        "optimizer = optim.Adam(\n",
        "    model.parameters(),\n",
        "    lr=0.001)\n"
      ],
      "metadata": {
        "id": "KDVP1AfsjQ7J"
      },
      "execution_count": 13,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "CrossEntropyLoss is used to calculate how different the model’s predictions are from the actual labels, and Adam optimizer updates the model’s weights to improve accuracy during training."
      ],
      "metadata": {
        "id": "MLfpuu2fs2jf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def calculate_accuracy(model, loader):\n",
        "\n",
        "    model.eval()\n",
        "\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    with torch.no_grad():\n",
        "\n",
        "        for images, labels in loader:\n",
        "\n",
        "            outputs = model(images)\n",
        "\n",
        "            _, predicted = torch.max(outputs, 1)\n",
        "\n",
        "            total += labels.size(0)\n",
        "\n",
        "            correct += (predicted == labels).sum().item()\n",
        "\n",
        "    return 100 * correct / total"
      ],
      "metadata": {
        "id": "0Ypeaw1ijUwH"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Evaluate the model by calculating the percentage of correct predictions on the dataset."
      ],
      "metadata": {
        "id": "LhiinXyCt2Xm"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "epochs = 20\n",
        "\n",
        "train_acc_list = []\n",
        "val_acc_list = []\n",
        "test_acc_list = []\n",
        "\n",
        "for epoch in range(epochs):\n",
        "\n",
        "    model.train()\n",
        "\n",
        "    for images, labels in train_loader:\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "\n",
        "        outputs = model(images)\n",
        "\n",
        "        loss = criterion(outputs, labels)\n",
        "\n",
        "        loss.backward()\n",
        "\n",
        "        optimizer.step()\n",
        "\n",
        "    train_acc = calculate_accuracy(\n",
        "        model,\n",
        "        train_loader)\n",
        "\n",
        "    val_acc = calculate_accuracy(\n",
        "        model,\n",
        "        val_loader)\n",
        "\n",
        "    test_acc = calculate_accuracy(\n",
        "        model,\n",
        "        test_loader)\n",
        "\n",
        "    train_acc_list.append(train_acc)\n",
        "    val_acc_list.append(val_acc)\n",
        "    test_acc_list.append(test_acc)\n",
        "\n",
        "    print(\n",
        "        f\"Epoch {epoch+1}/{epochs} | \"\n",
        "        f\"Train: {train_acc:.2f}% | \"\n",
        "        f\"Val: {val_acc:.2f}% | \"\n",
        "        f\"Test: {test_acc:.2f}%\")"
      ],
