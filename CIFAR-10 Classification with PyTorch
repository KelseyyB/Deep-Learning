        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "\n",
        "import torchvision\n",
        "import torchvision.transforms as transforms\n",
        "\n",
        "from torch.utils.data import DataLoader, random_split\n",
        "\n",
        "import matplotlib.pyplot as plt"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "In this cell, I imported all necessary libraries such as PyTorch, torchvision, and matplotlib for building the neural network, loading the CIFAR-10 dataset, and visualizing results."
      ],
      "metadata": {
        "id": "GaImaTGSqg-B"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "transform = transforms.Compose([\n",
        "    transforms.ToTensor()])\n",
        "train_full = torchvision.datasets.CIFAR10(\n",
        "    root='./data',\n",
        "    train=True,\n",
        "    download=True,\n",
        "    transform=transform)\n",
        "\n",
        "test_dataset = torchvision.datasets.CIFAR10(\n",
        "    root='./data',\n",
        "    train=False,\n",
        "    download=True,\n",
        "    transform=transform)\n",
        "# Load CIFAR-10 training and test datasets\n",
        "print(len(train_full))\n",
        "print(len(test_dataset))"
      ],
      "metadata": {
        "id": "2GW3S9POGPNr",
