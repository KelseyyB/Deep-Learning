          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Here, I split the original training dataset into training and validation sets using an 80:20 ratio."
      ],
      "metadata": {
        "id": "Gzrl71ZbrIqa"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "batch_size = 128\n",
        "train_loader = DataLoader(\n",
        "    train_dataset,\n",
        "    batch_size=batch_size,\n",
        "    shuffle=True)\n",
        "\n",
        "val_loader = DataLoader(\n",
        "    val_dataset,\n",
        "    batch_size=batch_size,\n",
        "    shuffle=False)\n",
        "\n",
        "test_loader = DataLoader(\n",
        "    test_dataset,\n",
        "    batch_size=batch_size,\n",
        "    shuffle=False)"
      ],
      "metadata": {
        "id": "hbG719lrHAne"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "This cell creates DataLoaders, which help load data in batches during training and evaluation."
      ],
      "metadata": {
        "id": "uhTUJezirZoV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class FFNClassifier(nn.Module):\n",
        "\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "\n",
        "        self.network = nn.Sequential(\n",
        "\n",
        "            nn.Flatten(),\n",
        "\n",
        "            nn.Linear(3072, 1024),\n",
        "            nn.ReLU(),\n",
        "\n",
        "\n",
        "            nn.Linear(1024, 512),\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(512, 256),\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(256, 10))\n",
        "\n",
        "    def forward(self, x):\n",
        "        return self.network(x)"
      ],
      "metadata": {
        "id": "VQTTF8OrjL1B"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Defines a feed-forward neural network that flattens CIFAR-10 images and uses fully connected layers with ReLU to predict one of 10 classes."
      ],
      "metadata": {
        "id": "3CVd_OGirbVs"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "model = FFNClassifier()\n",
        "\n",
        "print(model)"
      ],
      "metadata": {
        "id": "VqOtLe2SjObC",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "1225d2ea-1332-4006-985d-849174027689"
      },
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "FFNClassifier(\n",
            "  (network): Sequential(\n",
            "    (0): Flatten(start_dim=1, end_dim=-1)\n",
            "    (1): Linear(in_features=3072, out_features=1024, bias=True)\n",
            "    (2): ReLU()\n",
            "    (3): Linear(in_features=1024, out_features=512, bias=True)\n",
            "    (4): ReLU()\n",
            "    (5): Linear(in_features=512, out_features=256, bias=True)\n",
            "    (6): ReLU()\n",
